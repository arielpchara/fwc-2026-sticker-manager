{
  "name": "figurinhas-da-copa-troca",
  "version": "1.0.0",
  "type": "module",
  "bin": {
    "sticker-trade": "./dist/cli.js"
  },
  "scripts": {
    "cli": "tsx src/cli/index.ts",
    "dev:cli": "tsx watch src/cli/index.ts",
    "dev:mcp": "tsx watch src/mcp/server.ts",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
